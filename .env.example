# MobSF
MOBSF_URL=http://localhost:8000
MOBSF_API_KEY=your_mobsf_api_key_here

# Language the AI writes reports in (any language works, not just British English)
REPORT_LANGUAGE=British English

# Which AI provider to use by default:
# ollama | lmstudio | claude | openai | gemini | groq | mistral | openrouter
PROVIDER=ollama

# --- Local providers ---

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
# Context window size — increase for large APKs or complex reports (default: 32768)
# Gemma 4 / Qwen 2.5 support up to 128k; set lower on machines with limited VRAM
OLLAMA_NUM_CTX=32768

# LM Studio (OpenAI-compatible local server)
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=local-model

# --- Cloud providers (fill in the one you want to use) ---

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Groq (ultra-fast, generous free tier — console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Mistral AI (console.mistral.ai)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# OpenRouter — one key, 100+ models (openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
